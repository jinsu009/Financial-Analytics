# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Dependency directories
# 가장 중요! 용량이 크고 npm install로 언제든 다시 받을 수 있으므로 제외합니다.
node_modules/

# TypeScript
*.tsbuildinfo

# Build outputs
# 빌드 결과물은 서버에 올릴 때 새로 생성하므로 제외합니다.
dist/
dist-ssr/
*.local

# Environment variables
# API 키나 비밀번호가 들어가는 환경 변수 파일은 절대 올리면 안 됩니다!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS Metadata
# 맥이나 윈도우 시스템이 자동으로 만드는 설정 파일들입니다.
.DS_Store
Thumbs.db

# IDE Settings
# 에디터 개인 설정 폴더들입니다.
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache